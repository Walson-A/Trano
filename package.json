{
  "name": "trano",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n web,server -c cyan,magenta \"npm run dev -w @trano/web\" \"npm run dev -w @trano/server\"",
    "build": "npm run build -w @trano/web",
    "start": "npm run start -w @trano/server",
    "lint": "npm run lint --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
