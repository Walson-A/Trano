# Secrets du serveur Trano en développement (copier vers .env).
# En production (add-on HAOS), ces valeurs viennent des options de l'add-on.

# Connexion Home Assistant (pour /api/config et les outils de l'assistant)
TRANO_HA_URL=http://homeassistant.local:8123
TRANO_HA_TOKEN=votre_token_longue_duree

# Entité météo exposée au frontend
TRANO_WEATHER_ENTITY=weather.forecast_home

# Assistant IA (OpenRouter)
TRANO_OPENROUTER_KEY=sk-or-...
TRANO_OPENROUTER_MODEL=deepseek/deepseek-chat-v3.1:free
